{
  "name": "lumina-desktop",
  "version": "1.0.0",
  "description": "Lumina: Your memories, enlightened. An AI-powered gallery for the modern era.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w better-sqlite3,sharp",
    "test": "node test/basic.test.js",
    "lint": "npx eslint . --ext .js --max-warnings 0",
    "format": "npx prettier --write \"src/**/*.{js,css,html}\" \"lib/**/*.js\"",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "keywords": [
    "electron",
    "photo-gallery",
    "ai",
    "clip",
    "face-recognition",
    "semantic-search"
  ],
  "author": "Vishal",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.8.0",
    "electron-log": "^5.4.3",
    "exifr": "^7.1.3",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "heic-convert": "^2.1.0",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.vishal.lumina",
    "productName": "Lumina",
    "copyright": "Copyright © 2026 Vishal",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable",
        "zip"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.photography",
      "darkModeSupport": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Graphics;Photography"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Lumina"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/ffmpeg",
      "**/node_modules/ffmpeg-static/ffmpeg.exe",
      "**/node_modules/ffprobe-static/bin/**/*"
    ],
    "files": [
      "**/*",
      "!dist",
      "!test",
      "!docs",
      "!.github",
      "!*.log",
      "!.gitignore",
      "!tmp"
    ]
  }
}
